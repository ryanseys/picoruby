class Prism

  # @sidebar error
  class ParseError
    @message: String
    @location: Prism::Location
  end

  class Location
    def inspect: () -> String
  end

  class ParseResult
    @errors: [Prism::ParseError]
  end

  # Pretty-printed AST dump (empty when prism is built with
  # PRISM_EXCLUDE_PRETTYPRINT, e.g. when reusing mruby-compiler's prism).
  def self.parse: (String source) -> String
  # [[token_type, start_offset, end_offset], ...]
  def self.lex: (String source) -> Array[[Symbol, Integer, Integer]]
  # [{ message: String, line: Integer, column: Integer }, ...]
  def self.errors: (String source) -> Array[Hash[Symbol, untyped]]
end

class String
  def prettyprint: () -> nil
end
